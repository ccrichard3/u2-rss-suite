# 必填
U2_COOKIE=
U2_PASSKEY=

# 代理，可留空
HTTP_PROXY=
HTTPS_PROXY=

# 扫描频率
INTERVAL=300

# 规则
DOWNLOAD_STICKY=true
DOWNLOAD_NO_SEEDER_STICKY=true
DOWNLOAD_NO_FREE_STICKY=false
DOWNLOAD_NO_FREE_NON_STICKY=false
EVAL_ALL_KEYS=false
SKIP_EXISTING_ON_FIRST_RUN=true

# RSS
RSS_MAX_ITEMS=50
RSS_TITLE=U2 New Torrents
RSS_LINK=https://u2.dmhy.org/
RSS_DESCRIPTION=Auto-generated RSS feed for new torrents.
RSS_HTTP_BIND=0.0.0.0
RSS_HTTP_PORT=8788
DATA_DIR=/app/data
